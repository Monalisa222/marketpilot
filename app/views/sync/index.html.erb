<div class="px-8 py-6">

  <!-- Header -->
  <div class="mb-6">
    <h1 class="text-2xl font-semibold text-gray-800">
      Sync Dashboard
    </h1>
    <p class="text-sm text-gray-500 mt-1">
      Manage synchronization and repricing across marketplaces
    </p>
  </div>

  <!-- Accounts Grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">

    <% @accounts.each do |account| %>

      <div class="bg-white border rounded-xl shadow-sm p-5">

        <!-- Account Name -->
        <div class="mb-4">
          <h2 class="text-lg font-medium text-gray-800">
            <%= account.account_name %>
          </h2>
          <p class="text-xs text-gray-400">
            Marketplace Sync Actions
          </p>
        </div>

        <!-- Actions -->
        <div class="space-y-2">

          <%= button_to "Sync Orders",
                sync_orders_sync_index_path(account_id: account.id),
                method: :post,
                class: "w-full bg-gray-900 text-white px-4 py-2 rounded-lg text-sm hover:bg-gray-800 transition" %>

          <%= button_to "Sync Products",
                sync_products_sync_index_path(account_id: account.id),
                method: :post,
                class: "w-full bg-gray-100 text-gray-700 px-4 py-2 rounded-lg text-sm hover:bg-gray-200 transition" %>

          <%= button_to "Run Repricing",
                sync_repricing_sync_index_path(account_id: account.id),
                method: :post,
                class: "w-full bg-green-600 text-white px-4 py-2 rounded-lg text-sm hover:bg-green-700 transition" %>

        </div>

      </div>

    <% end %>

  </div>

  <!-- Empty State -->
  <% if @accounts.empty? %>
    <div class="mt-10 text-center text-gray-500">
      No marketplace accounts connected
    </div>
  <% end %>

</div>
