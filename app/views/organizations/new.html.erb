<div class="max-w-md mx-auto mt-10">

  <h1 class="text-2xl font-bold mb-6">
    Create Organization
  </h1>

  <%= form_with model: @organization do |f| %>

    <%= render "shared/form_errors", object: @organization %>

    <div class="mb-4">
      <%= f.label :name %>
      <%= f.text_field :name, class: "w-full border rounded p-2" %>
    </div>

    <%= f.submit "Create Organization",
        class: "bg-blue-600 text-white px-4 py-2 rounded" %>

  <% end %>

</div>
