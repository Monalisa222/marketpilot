<div class="max-w-md mx-auto mt-10">
  <h1 class="text-2xl font-bold mb-6">Create Account</h1>

  <%= render "shared/form_errors", object: @user %>

  <%= form_with model: @user, url: registrations_path, data: { turbo: false } do |f| %>

    <div class="mb-4">
      <%= f.label :name, class: "block mb-1 font-medium" %>
      <%= f.text_field :name, class: "w-full border rounded p-2" %>
    </div>

    <div class="mb-4">
      <%= f.label :email, class: "block mb-1 font-medium" %>
      <%= f.email_field :email, class: "w-full border rounded p-2" %>
    </div>

    <div class="mb-4">
      <%= f.label :password, class: "block mb-1 font-medium" %>
      <%= f.password_field :password, class: "w-full border rounded p-2" %>
    </div>

    <div class="mb-4">
      <%= f.label :password_confirmation, class: "block mb-1 font-medium" %>
      <%= f.password_field :password_confirmation, class: "w-full border rounded p-2" %>
    </div>

    <%= f.submit "Sign up", class: "bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700" %>

  <% end %>
</div>
