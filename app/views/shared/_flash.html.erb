<% flash.each do |type, message| %>
  <div class="mb-3 px-4 py-3 rounded shadow-lg text-sm font-medium
              <%= type == "notice" ? "bg-green-500 text-white" : "bg-red-500 text-white" %>">

    <div class="flex justify-between items-center">
      <span><%= message %></span>

      <button onclick="this.parentElement.parentElement.remove()"
              class="ml-3 text-white font-bold">
        ✕
      </button>
    </div>

  </div>
<% end %>
