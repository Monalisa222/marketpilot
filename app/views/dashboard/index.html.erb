<div class="min-h-screen bg-gray-50">

  <div class="px-6 py-6">

    <!-- Header -->
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-800">Dashboard</h1>
      <p class="text-gray-500 mt-1">
        Welcome back 👋 Here’s what’s happening today
      </p>
    </div>

    <% if current_organization %>

      <!-- Active Organization -->
      <div class="bg-gradient-to-r from-blue-500 to-indigo-600 text-white rounded-xl p-6 shadow mb-8">
        <h2 class="text-lg opacity-90">Active Organization</h2>
        <p class="text-2xl font-bold mt-1">
          <%= current_organization.name %>
        </p>

        <div class="mt-3 text-sm opacity-90">
          <%= pluralize(current_organization.products.count, "product") %> •
          <%= pluralize(current_organization.orders.count, "order") %>
        </div>
      </div>

      <!-- Stats -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">

        <div class="bg-white p-6 rounded-xl shadow-sm hover:shadow-md transition">
          <p class="text-sm text-gray-500">Products</p>
          <h2 class="text-3xl font-bold mt-2 text-gray-800">
            <%= current_organization.products.count %>
          </h2>
        </div>

        <div class="bg-white p-6 rounded-xl shadow-sm hover:shadow-md transition">
          <p class="text-sm text-gray-500">Orders</p>
          <h2 class="text-3xl font-bold mt-2 text-gray-800">
            <%= current_organization.orders.count %>
          </h2>
        </div>

        <div class="bg-white p-6 rounded-xl shadow-sm hover:shadow-md transition">
          <p class="text-sm text-gray-500">Sync Events</p>
          <h2 class="text-3xl font-bold mt-2 text-gray-800">
            <%= current_organization.sync_events.count %>
          </h2>
        </div>

      </div>

      <!-- Quick Actions -->
      <div class="bg-white rounded-xl shadow-sm p-6 mb-8">
        <h2 class="text-lg font-semibold mb-4 text-gray-800">Quick Actions</h2>

        <div class="flex flex-wrap gap-3">
          <%= link_to "Add Product",
                new_product_path,
                class: "bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700" %>

          <%= link_to "View Orders",
                orders_path,
                class: "bg-gray-100 px-4 py-2 rounded-lg hover:bg-gray-200" %>

          <%= link_to "Sync Events",
                sync_events_path,
                class: "bg-green-600 text-white px-4 py-2 rounded-lg hover:bg-green-700" %>
        </div>
      </div>

    <% else %>

      <!-- No Org -->
      <div class="bg-yellow-50 border border-yellow-200 rounded-xl p-6 text-center">
        <h2 class="text-lg font-semibold text-yellow-700 mb-2">
          No Active Organization
        </h2>
        <p class="text-gray-600">
          Please select an organization from the navbar.
        </p>
      </div>

    <% end %>

  </div>

</div>
