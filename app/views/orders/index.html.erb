<div class="max-w-7xl mx-auto">

  <h1 class="text-2xl font-bold mb-6">
    Orders
  </h1>

  <div class="bg-white shadow rounded">

    <table class="w-full">

      <thead class="bg-gray-100">
        <tr>
          <th class="p-3 text-left">Order</th>
          <th class="p-3 text-left">Marketplace</th>
          <th class="p-3 text-left">Status</th>
          <th class="p-3 text-left">Total</th>
        </tr>
      </thead>

      <tbody>

        <% @orders.each do |order| %>

          <tr class="border-t">

            <td class="p-3">
              <%= link_to order.external_id, order_path(order) %>
            </td>

            <td class="p-3">
              <%= order.marketplace_account.marketplace %>
            </td>

            <td class="p-3">
              <%= order.status %>
            </td>

            <td class="p-3">
              <%= order.total_price %>
            </td>

          </tr>

        <% end %>

      </tbody>

    </table>

  </div>

</div>
