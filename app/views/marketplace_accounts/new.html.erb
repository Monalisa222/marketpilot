<div class="px-8 py-6">

  <!-- Header -->
  <div class="mb-6">
    <h1 class="text-2xl font-semibold text-gray-800">
      Connect Marketplace
    </h1>
    <p class="text-sm text-gray-500 mt-1">
      Add your marketplace credentials to start syncing data
    </p>
  </div>

  <!-- Form Card -->
  <div class="bg-white border rounded-xl shadow-sm p-6 max-w-lg">

    <%= form_with model: @account do |f| %>

      <%= render "shared/form_errors", object: @account %>

      <!-- Marketplace -->
      <div class="mb-5">
        <%= f.label :marketplace, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.select :marketplace,
              ["shopify", "ebay"],
              {},
              class: "w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-gray-900" %>
      </div>

      <!-- API Key -->
      <div class="mb-5">
        <%= f.label :api_key, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :api_key,
              class: "w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-gray-900",
              placeholder: "Enter API key" %>
      </div>

      <!-- API Secret -->
      <div class="mb-6">
        <%= f.label :api_secret, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :api_secret,
              class: "w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-gray-900",
              placeholder: "Enter API secret" %>
      </div>

      <!-- Submit -->
      <div class="flex justify-end">
        <%= f.submit "Connect",
              class: "bg-gray-900 text-white px-5 py-2 rounded-lg text-sm hover:bg-gray-800 transition" %>
      </div>

    <% end %>

  </div>

</div>
