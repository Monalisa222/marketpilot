<div class="px-8 py-6">

  <!-- Header -->
  <div class="mb-6">
    <h1 class="text-2xl font-semibold text-gray-800">
      Connect Marketplace
    </h1>
    <p class="text-sm text-gray-500 mt-1">
      Add your marketplace credentials to start syncing data
    </p>
  </div>

  <!-- Form Card -->
  <div class="bg-white border rounded-xl shadow-sm p-6 max-w-lg">

    <%= form_with model: @account do |f| %>

      <%= render "shared/form_errors", object: @account %>

      <!-- Account Name -->
      <div class="mb-5">
        <label class="block text-sm font-medium text-gray-700 mb-1">
          Account Name
          <span class="text-red-500">*</span>
        </label>

        <%= f.text_field :account_name,
              required: true,
              placeholder: "Enter Account Name",
              class: "w-full border rounded-lg px-3 py-2 text-sm 
                      focus:outline-none focus:ring-2 focus:ring-gray-900 transition" %>
      </div>

      <!-- Marketplace -->
      <div class="mb-5">
        <%= f.label :marketplace, class: "block text-sm font-medium text-gray-700 mb-1" %>

        <%= f.select :marketplace,
              MarketplaceConfigService.marketplaces.map { |mp| [MarketplaceConfigService.name_for(mp), mp] },
              {},
              id: "marketplace_select",
              class: "w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-gray-900" %>
      </div>

      <!-- Dynamic Fields -->
      <div id="credentials_fields" class="space-y-5"></div>

      <!-- Submit Buttons -->
      <div class="mt-6 flex justify-end gap-3">

        <!-- Default Submit -->
        <%= f.submit "Connect Account",
              id: "default_submit",
              class: "bg-gray-900 text-white px-5 py-2 rounded-lg text-sm hover:bg-gray-800 transition" %>

        <!-- eBay Button -->
        <button type="button"
                id="ebay_submit"
                class="hidden bg-blue-600 text-white px-5 py-2 rounded-lg text-sm hover:bg-blue-500 transition">
          Connect eBay Account
        </button>

      </div>

    <% end %>

  </div>

</div>


<script>
  document.addEventListener("turbo:load", function () {

    const config = <%= raw MarketplaceConfigService.config.to_json %>

    const select = document.getElementById("marketplace_select")
    const container = document.getElementById("credentials_fields")
    const defaultSubmit = document.getElementById("default_submit")
    const ebaySubmit = document.getElementById("ebay_submit")

    if (!select || !container) return

    function formatLabel(text) {
      return text.replace(/_/g, " ").replace(/\b\w/g, l => l.toUpperCase())
    }

    function toggleButtons(marketplace) {
      if (marketplace === "ebay") {
        defaultSubmit.classList.add("hidden")
        ebaySubmit.classList.remove("hidden")
      } else {
        defaultSubmit.classList.remove("hidden")
        ebaySubmit.classList.add("hidden")
      }
    }

    function renderFields(marketplace) {
      container.innerHTML = ""

      if (!config[marketplace]) return

      const credentials = config[marketplace]["credentials"]

      // Fix: handle null / undefined / empty
      if (!credentials || credentials.length === 0) return

      credentials.forEach(field => {

        const isSecret = field.includes("secret") || field.includes("key")

        const fieldHTML = `
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">
              ${formatLabel(field)}
              <span class="text-red-500">*</span>
            </label>

            <input type="${isSecret ? 'password' : 'text'}"
                  name="credentials[${field}]"
                  placeholder="Enter ${formatLabel(field)}"
                  required
                  class="w-full border rounded-lg px-3 py-2 text-sm 
                          focus:outline-none focus:ring-2 focus:ring-gray-900 transition">
          </div>
        `

        container.insertAdjacentHTML("beforeend", fieldHTML)
      })
    }

    // eBay redirect logic
    ebaySubmit.addEventListener("click", function () {
      const form = this.closest("form")
      const formData = new FormData(form)
      const params = new URLSearchParams(formData)

      window.location.href = `/ebay/connect?${params.toString()}`
    })

    // On marketplace change
    select.addEventListener("change", function () {
      renderFields(this.value)
      toggleButtons(this.value)
    })

    // Initial load
    renderFields(select.value)
    toggleButtons(select.value)

  })
</script>
